{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:pwa",
  "installCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/app/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/app/"
        }
      ]
    },
    {
      "source": "/app/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ]
}
