{
  "name": "organic-todo",
  "private": true,
  "version": "1.0.2",
  "description": "Grove — tasks, focus & memo for desktop and mobile (PWA)",
  "homepage": "https://grove-todo.vercel.app",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:pwa": "node scripts/build-pwa.mjs",
    "vercel-build": "npm run build:pwa",
    "pwa:preview": "npm run build:pwa && npx --yes serve app -p 4173",
    "cap:sync": "npm run build:pwa && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npx cap run android",
    "cap:icons": "python scripts/prepare-icon.py",
    "cap:apk:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/assemble-debug-apk.ps1",
    "icons": "python scripts/prepare-icon.py && tauri icon public/Grove_icon_square.png && node -e \"const fs=require('fs');fs.copyFileSync('public/Grove_icon_square.png','assets/tray-icon.png');\"",
    "tauri": "tauri"
  },
  "keywords": [
    "todo",
    "focus",
    "pomodoro",
    "productivity",
    "tauri"
  ],
  "author": "Ethan Kunder",
  "license": "Apache-2.0",
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-os": "^2.3.2"
  }
}
